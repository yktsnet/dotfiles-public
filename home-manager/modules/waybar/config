{
    "layer": "top",
    "output": "eDP-1",
    "position": "top",
    "mode": "dock",
    "height": 26,
    "margin-top": 10,
    "margin-left": 15,
    "margin-right": 15,
    "spacing": 15,
    "exclusive": true,
    "modules-left": ["hyprland/workspaces"],
    "modules-center": ["clock#utc", "clock#jst"],
    "modules-right": ["custom/mpris", "pulseaudio", "custom/wall", "temperature", "group/hardware"],

    "hyprland/workspaces": {
        "format": "{icon}",
        "on-click": "activate",
        "all-outputs": false,
        "show-special": false,
        "persistent-workspaces": {
            "eDP-1": [4, 5, 6, 7]
        },
        "format-icons": {
            "1": "1",
            "2": "2",
            "3": "3",
            "4": "q",
            "5": "w",
            "6": "e",
            "7": "r"
        }
    },
    
    "group/hardware": {
        "orientation": "horizontal",
        "modules": [
            "cpu",
            "memory",
            "custom/power-mode",
            "battery"
        ]
    },

    "custom/mpris": {
        "format": "{}",
        "exec": "zscroll-mpris",
        "on-click": "playerctl play-pause",
        "on-scroll-up": "playerctl next",
        "on-scroll-down": "playerctl previous",
        "escape": true
    },

    "pulseaudio": {
        "format": "VOL {volume}",
        "format-muted": "VOL MUTED",
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "on-scroll-up": "wpctl set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 5%+",
        "on-scroll-down": "wpctl set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 5%-",
        "scroll-step": 5
    },

    "custom/wall": {
        "format": "WALL",
        "on-click": "swww-random",
        "on-click-right": "swww-random anime",
        "tooltip": false
    },

    "temperature": {
        "hwmon-path": "/sys/class/hwmon/hwmon5/temp1_input",
        "critical-threshold": 80,
        "format": "TEM {temperatureC} C",
        "tooltip": false
    },

    "clock#utc": {
        "timezone": "Etc/UTC",
        "format": "{:%H:%M UTC}",
        "tooltip": false
    },

    "clock#jst": {
        "timezone": "Asia/Tokyo",
        "format": "{:%H:%M JST}",
        "format-alt": "{:%Y-%m-%d}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "month",
            "on-scroll": 1,
            "format": {
                "today": "<span color='#89ddff'><b><u>{}</u></b></span>"
            }
        }
    },

    "cpu": {
        "format": "CPU {usage}%"
    },

    "memory": {
        "format": "MEM {percentage}%"
    },

    "custom/power-mode": {
        "exec": "threshold=$(cat /sys/class/power_supply/BAT0/charge_control_end_threshold); if [ \"$threshold\" = \"100\" ]; then echo '{\"text\": \" \", \"class\": \"full-mode\"}'; else echo '{\"text\": \" \", \"class\": \"storage-mode\"}'; fi",
        "interval": "once",
        "signal": 1,
        "return-type": "json",
        "format": "{}",
        "tooltip": false
    },

    "battery": {
        "format": "BAT {capacity}%"
    }
}
